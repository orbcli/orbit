{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${PLUGIN_ROOT}/hooks/codex/session-start.sh\"",
            "statusMessage": "Loading orbit workspace context"
          }
        ]
      },
      {
        "matcher": "resume|clear|compact",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${PLUGIN_ROOT}/hooks/codex/session-resume.sh\"",
            "statusMessage": "Restoring orbit workspace context"
          }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${PLUGIN_ROOT}/hooks/codex/auto-approve.sh\"",
            "statusMessage": "Checking orbit command"
          }
        ]
      }
    ]
  }
}
