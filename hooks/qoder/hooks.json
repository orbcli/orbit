{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup",
        "hooks": [
          { "type": "command", "command": "bash \"${QODER_PLUGIN_ROOT}/hooks/session-start.sh\"" }
        ]
      },
      {
        "matcher": "resume",
        "hooks": [
          { "type": "command", "command": "bash \"${QODER_PLUGIN_ROOT}/hooks/session-resume.sh\"" }
        ]
      },
      {
        "matcher": "compact",
        "hooks": [
          { "type": "command", "command": "bash \"${QODER_PLUGIN_ROOT}/hooks/session-resume.sh\"" }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          { "type": "command", "command": "bash \"${QODER_PLUGIN_ROOT}/hooks/auto-approve.sh\"" }
        ]
      }
    ]
  }
}
